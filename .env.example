# HELIOS Environment Configuration

# -------------------------
# API / Backend Services
# -------------------------
APP_NAME=HELIOS API
APP_VERSION=1.0.0
ENVIRONMENT=development
LOG_LEVEL=DEBUG
DEBUG=false
API_HOST=0.0.0.0
API_PORT=8000
ENABLE_DOCS=true
ALLOWED_ORIGINS=http://localhost:3000
ALLOWED_HOSTS=localhost,127.0.0.1

# Metadata Database
# Default is local SQLite. Replace with Postgres in shared environments.
DATABASE_URL=sqlite:///./datasets/helios_meta.db

# Cache / Coordination (Redis)
REDIS_URL=redis://localhost:6379/0

# Analytical Engine (DuckDB)
DUCKDB_PATH=./datasets/helios_analytics.duckdb

# -------------------------
# Frontend
# -------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_ENVIRONMENT=development

# -------------------------
# Model Providers
# -------------------------
# Use any OpenAI-compatible provider (OpenAI, Azure OpenAI via proxy, vLLM, Ollama)
LLM_PROVIDER=openai
LLM_API_BASE=https://api.openai.com/v1
LLM_API_KEY=sk-your-key-here
LLM_MODEL=gpt-4-turbo-preview
